<%- include('partials/header') %>

<section class="hero" style="background-image: url('/images/hero-1.jpg');">
    <div class="hero-overlay"></div>
    <div class="container">
        <div class="hero-content">
            <span class="hero-tag">Holistic Development</span>
            <h1>Beyond Books — <br>Building Character</h1>
            <p>From state-of-the-art labs to sports, music & arts — we offer experiences that shape every dimension.</p>
            <div class="hero-btns">
                <a href="/admissions" class="btn-yellow">Apply for Admission</a>
                <a href="/about" class="btn-outline-white">Discover More</a>
            </div>
        </div>
    </div>
</section>

<section class="principal-section">
    <div class="container">
        <div class="principal-grid">
            <div class="principal-img-container">
                <img src="/images/rkr-principal.jpg" alt="Principal" class="principal-img">
            </div>
            <div class="principal-content">
                <span class="section-tag">From the Principal's Desk</span>
                <h2>A Message from Our Principal</h2>
                <div class="principal-quote">
                    <i class="fas fa-quote-left"></i>
                    <p>"At R.K.R. Public School, we believe every child is unique and deserves an education that nurtures both intellect and character. Our endeavour is to create a vibrant learning community where students are inspired to dream big, work hard, and grow into responsible, compassionate citizens of tomorrow."</p>
                </div>
                <div class="principal-info">
                    <h4>Mr. Harish Singh Padihar</h4>
                    <p>Principal, RKR Public School</p>
                </div>
                <a href="/principal" class="btn-outline" style="margin-top: 2rem; display: inline-flex; align-items: center; gap: 0.5rem;">Read Full Message <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>
    </div>
</section>

<section class="welcome-section">
    <div class="container">
        <div class="welcome-grid">
            <div class="welcome-content">
                <span class="section-tag" style="color: var(--accent);">About Our School</span>
                <h2 style="font-size: 3.5rem; color: var(--primary); margin-bottom: 2rem;">Welcome to R.K.R. Public School, Kanpur</h2>
                <p style="color: var(--text-muted); font-size: 1.1rem; margin-bottom: 2rem;">R.K.R. Public School is a premier co-educational, English medium school in Kanpur, affiliated to CBSE. We are dedicated to providing a stimulating learning environment where every child is empowered to discover their potential, embrace values, and prepare for a bright future.</p>
                
                <div class="features-list">
                    <div class="feature-item"><i class="fas fa-check-circle"></i> CBSE Affiliated Curriculum</div>
                    <div class="feature-item"><i class="fas fa-check-circle"></i> Experienced Faculty</div>
                    <div class="feature-item"><i class="fas fa-check-circle"></i> Smart Digital Classrooms</div>
                    <div class="feature-item"><i class="fas fa-check-circle"></i> Safe & Caring Campus</div>
                    <div class="feature-item"><i class="fas fa-check-circle"></i> Sports & Cultural Activities</div>
                    <div class="feature-item"><i class="fas fa-check-circle"></i> GPS-enabled Transport</div>
                </div>
                
                <a href="/about" class="btn-primary" style="margin-top: 3rem; background: var(--primary); color: white;">Learn More <i class="fas fa-arrow-right" style="margin-left: 0.5rem;"></i></a>
            </div>
            <div class="welcome-img-container">
                <img src="/images/rkr-building.jpg" alt="School Building" class="welcome-img">
            </div>
        </div>
    </div>
</section>

<section class="news-section">
    <div class="container">
        <div class="news-header">
            <div>
                <span class="section-tag" style="color: var(--accent); font-weight: 800; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 2px;">Latest Updates</span>
                <h2 style="font-size: 3.5rem; color: var(--primary); margin-top: 0.5rem;">News & Events</h2>
            </div>
            <a href="/news" class="btn-outline">View All News</a>
        </div>
        
        <div class="news-grid">
            <div class="news-card">
                <img src="/images/rkr-kids-craft.jpg" alt="Event" class="news-img">
                <div class="news-body">
                    <div class="news-meta">
                        <span class="news-tag">Event</span>
                        <span class="news-date">12 Sep 2025</span>
                    </div>
                    <h3>Annual Cultural Fest 'Utsav 2025' Concludes with a Grand Show</h3>
                    <a href="#" class="read-more">Read More <i class="fas fa-chevron-right"></i></a>
                </div>
            </div>
            <div class="news-card">
                <img src="/images/rkr-science-model.jpg" alt="Achievement" class="news-img">
                <div class="news-body">
                    <div class="news-meta">
                        <span class="news-tag" style="background: #0f172a;">Achievement</span>
                        <span class="news-date">28 Aug 2025</span>
                    </div>
                    <h3>RKRPS Students Win Inter-School Science Quiz Competition</h3>
                    <a href="#" class="read-more">Read More <i class="fas fa-chevron-right"></i></a>
                </div>
            </div>
            <div class="news-card">
                <img src="/images/hero-3.jpg" alt="Notice" class="news-img">
                <div class="news-body">
                    <div class="news-meta">
                        <span class="news-tag" style="background: #d97706;">Notice</span>
                        <span class="news-date">10 Aug 2025</span>
                    </div>
                    <h3>Independence Day Celebrations — Parents Invited</h3>
                    <a href="#" class="read-more">Read More <i class="fas fa-chevron-right"></i></a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="cta-section">
    <div class="container">
        <span style="color: var(--accent-light); font-weight: 800; text-transform: uppercase; font-size: 0.9rem; letter-spacing: 3px; display: block; margin-bottom: 1.5rem;">Admissions Open 2026-27</span>
        <h2>Begin Your Child's Journey at RKRPS</h2>
        <p>Limited seats available. Apply online today and take the first step towards a future filled with possibilities.</p>
        <div class="hero-btns" style="justify-content: center;">
            <a href="/admissions" class="btn-yellow">Apply Online</a>
            <a href="/contact" class="btn-outline-white">Contact Us</a>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
