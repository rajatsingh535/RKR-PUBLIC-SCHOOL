<%- include('partials/header') %>

<div style="background: var(--primary); padding: 4rem 0;">
    <div class="container">
        <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 2rem;">
            <div>
                <span class="section-tag" style="color: var(--accent-light);">Administration</span>
                <h2 style="color: white; font-size: 2.8rem;">Admin Dashboard</h2>
                <p style="color: rgba(255,255,255,0.6); margin-top: 0.5rem;">Logged in as: <strong style="color: var(--accent-light);"><%= user.name %></strong></p>
            </div>
            <div style="display: flex; gap: 1.5rem; flex-wrap: wrap;">
                <div style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1); padding: 1.5rem 2.5rem; border-radius: 10px; text-align: center;">
                    <div style="font-size: 2.5rem; font-weight: 800; color: var(--accent-light);"><%= admissions.length %></div>
                    <div style="color: rgba(255,255,255,0.6); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;">Total</div>
                </div>
                <div style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1); padding: 1.5rem 2.5rem; border-radius: 10px; text-align: center;">
                    <div style="font-size: 2.5rem; font-weight: 800; color: #34d399;"><%= admissions.filter(a => a.status === 'Approved').length %></div>
                    <div style="color: rgba(255,255,255,0.6); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;">Approved</div>
                </div>
                <div style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1); padding: 1.5rem 2.5rem; border-radius: 10px; text-align: center;">
                    <div style="font-size: 2.5rem; font-weight: 800; color: #fbbf24;"><%= admissions.filter(a => a.status === 'Pending').length %></div>
                    <div style="color: rgba(255,255,255,0.6); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;">Pending</div>
                </div>
                <div style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1); padding: 1.5rem 2.5rem; border-radius: 10px; text-align: center;">
                    <div style="font-size: 2.5rem; font-weight: 800; color: #f87171;"><%= admissions.filter(a => a.status === 'Rejected').length %></div>
                    <div style="color: rgba(255,255,255,0.6); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;">Rejected</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div style="padding: 60px 0; background: var(--bg-soft);">
    <div class="container">
        <% if (admissions.length === 0) { %>
            <div class="glass-card" style="text-align: center; padding: 5rem 2rem;">
                <i class="fas fa-inbox" style="font-size: 4rem; color: #cbd5e1; margin-bottom: 1.5rem; display: block;"></i>
                <h3 style="color: var(--text-muted); font-size: 1.5rem; margin-bottom: 1rem;">No Applications Yet</h3>
                <p style="color: var(--text-muted);">Admission applications will appear here once students submit the form.</p>
            </div>
        <% } else { %>
            <div style="background: white; border-radius: 12px; box-shadow: var(--card-shadow); overflow: hidden;">
                <div style="padding: 1.5rem 2rem; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
                    <h3 style="color: var(--primary); font-size: 1.2rem;">All Applications</h3>
                    <span style="font-size: 0.85rem; color: var(--text-muted);"><%= admissions.length %> total record(s)</span>
                </div>
                <div style="overflow-x: auto;">
                    <table>
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Student Name</th>
                                <th>Class</th>
                                <th>Parent</th>
                                <th>Phone</th>
                                <th>Email</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% admissions.forEach((record, i) => { %>
                                <tr id="row-<%= record._id %>">
                                    <td style="color: var(--text-muted); font-size: 0.85rem; white-space: nowrap;"><%= i + 1 %></td>
                                    <td style="font-weight: 700; color: var(--primary); white-space: nowrap;"><%= record.studentName %></td>
                                    <td style="white-space: nowrap;"><span style="background:#e0f2fe;color:#0369a1;padding:0.2rem 0.8rem;border-radius:99px;font-size:0.82rem;font-weight:700;">Class <%= record.classApplying %></span></td>
                                    <td style="white-space: nowrap;"><%= record.parentName %></td>
                                    <td style="white-space: nowrap;"><a href="tel:<%= record.phone %>" style="color:var(--accent);font-weight:600;"><%= record.phone %></a></td>
                                    <td style="font-size:0.88rem; white-space: nowrap;"><%= record.email %></td>
                                    <td style="font-size:0.85rem;color:var(--text-muted); white-space: nowrap;"><%= new Date(record.submittedAt).toLocaleDateString('en-IN') %></td>
                                    <td style="white-space: nowrap;">
                                        <% if (record.status === 'Approved') { %>
                                            <span class="badge-approved">✓ Approved</span>
                                        <% } else if (record.status === 'Rejected') { %>
                                            <span class="badge-rejected">✕ Rejected</span>
                                        <% } else { %>
                                            <span class="badge-pending">⏳ Pending</span>
                                        <% } %>
                                    </td>
                                    <td style="white-space: nowrap;">
                                        <div style="display:flex;gap:0.5rem;flex-wrap:nowrap;">
                                            <button onclick="updateStatus('<%= record._id %>', 'Approved')"
                                                style="background:#d1fae5;color:#065f46;border:none;padding:0.45rem 1rem;border-radius:6px;font-weight:700;cursor:pointer;font-size:0.82rem;font-family:inherit;transition:all 0.2s;"
                                                onmouseover="this.style.background='#059669';this.style.color='white'"
                                                onmouseout="this.style.background='#d1fae5';this.style.color='#065f46'">
                                                <i class="fas fa-check"></i> Approve
                                            </button>
                                            <button onclick="updateStatus('<%= record._id %>', 'Rejected')"
                                                style="background:#fee2e2;color:#991b1b;border:none;padding:0.45rem 1rem;border-radius:6px;font-weight:700;cursor:pointer;font-size:0.82rem;font-family:inherit;transition:all 0.2s;"
                                                onmouseover="this.style.background='#dc2626';this.style.color='white'"
                                                onmouseout="this.style.background='#fee2e2';this.style.color='#991b1b'">
                                                <i class="fas fa-times"></i> Reject
                                            </button>
                                            <button onclick="document.getElementById('manageModal_<%= record._id %>').showModal()"
                                                style="background:#f3e8ff;color:#7e22ce;border:none;padding:0.45rem 1rem;border-radius:6px;font-weight:700;cursor:pointer;font-size:0.82rem;font-family:inherit;transition:all 0.2s;"
                                                onmouseover="this.style.background='#a855f7';this.style.color='white'"
                                                onmouseout="this.style.background='#f3e8ff';this.style.color='#7e22ce'">
                                                <i class="fas fa-cog"></i> Manage
                                            </button>
                                            <button onclick="deleteRecord('<%= record._id %>')"
                                                style="background:#f1f5f9;color:#64748b;border:none;padding:0.45rem 0.8rem;border-radius:6px;font-weight:700;cursor:pointer;font-size:0.82rem;font-family:inherit;transition:all 0.2s;"
                                                onmouseover="this.style.background='#ef4444';this.style.color='white'"
                                                onmouseout="this.style.background='#f1f5f9';this.style.color='#64748b'">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- ALL MANAGE MODALS (outside the table) -->
            <% admissions.forEach(record => { %>
                <dialog id="manageModal_<%= record._id %>" style="border:none; border-radius: 12px; padding: 2rem; max-width: 600px; width: 90%; box-shadow: 0 10px 25px rgba(0,0,0,0.2); z-index: 9999;">
                    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); padding-bottom: 1rem; margin-bottom: 1.5rem;">
                        <h3 style="color: var(--primary); margin: 0;">Manage: <%= record.studentName %></h3>
                        <button onclick="document.getElementById('manageModal_<%= record._id %>').close()" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: var(--text-muted);">&times;</button>
                    </div>
                    
                    <!-- Documents Section -->
                    <div style="margin-bottom: 2rem;">
                        <h4 style="margin-bottom: 0.5rem; color: var(--primary);">Uploaded Documents</h4>
                        <% if (!record.documents || record.documents.length === 0) { %>
                            <p style="font-size: 0.9rem; color: var(--text-muted);">No documents uploaded.</p>
                        <% } else { %>
                            <ul style="list-style: none; padding: 0;">
                                <% (record.documents || []).forEach(doc => { %>
                                    <li style="display: flex; justify-content: space-between; padding: 0.5rem; background: var(--bg-soft); margin-bottom: 0.5rem; border-radius: 4px;">
                                        <span><%= doc.name %></span>
                                        <a href="<%= doc.data %>" target="_blank" style="color: var(--accent); font-weight: bold; font-size: 0.85rem;">View</a>
                                    </li>
                                <% }) %>
                            </ul>
                        <% } %>
                    </div>

                    <!-- Fees Section -->
                    <div style="margin-bottom: 2rem;">
                        <h4 style="margin-bottom: 0.5rem; color: var(--primary);">Set Fees</h4>
                        <div style="display: flex; gap: 1rem; align-items: center;">
                            <input type="number" id="feeInput_<%= record._id %>" value="<%= record.feesAmount %>" style="padding: 0.5rem; border: 1px solid var(--border); border-radius: 4px;" placeholder="Amount (₹)">
                            <button onclick="updateFees('<%= record._id %>')" style="background: var(--primary); color: white; border: none; padding: 0.5rem 1rem; border-radius: 4px; cursor: pointer;">Save Fees</button>
                        </div>
                        <% if (record.feesPaid) { %>
                            <p style="color: #059669; font-weight: bold; font-size: 0.85rem; margin-top: 0.5rem;">Fees verified &amp; paid ✅</p>
                            <% if (record.receiptNumber) { %>
                                <p style="font-size: 0.82rem; color: var(--text-muted); margin-top: 0.35rem;">Receipt: <strong><%= record.receiptNumber %></strong></p>
                            <% } %>
                            <a href="/receipt/<%= record._id %>" target="_blank" rel="noopener" style="display:inline-block;margin-top:0.6rem;font-size:0.82rem;color:var(--accent);font-weight:700;">Open receipt</a>
                        <% } else if (record.feesVerificationPending) { %>
                            <div style="background:#fffbeb;border:1px solid #fcd34d;border-radius:8px;padding:0.85rem;margin-top:0.5rem;">
                                <p style="margin:0 0 0.4rem 0;font-weight:700;color:#92400e;font-size:0.88rem;">Student submitted payment reference</p>
                                <p style="margin:0;font-size:0.85rem;"><strong>UTR / Ref:</strong> <%= record.studentPaymentReference %></p>
                                <% if (record.feesSubmittedAt) { %>
                                    <p style="margin:0.4rem 0 0;font-size:0.78rem;color:var(--text-muted);"><%= new Date(record.feesSubmittedAt).toLocaleString('en-IN') %></p>
                                <% } %>
                                <div style="display:flex;gap:0.5rem;margin-top:0.75rem;flex-wrap:wrap;">
                                    <button type="button" onclick="verifyFeePayment('<%= record._id %>')" style="background:#059669;color:#fff;border:none;padding:0.45rem 1rem;border-radius:6px;font-weight:700;cursor:pointer;font-size:0.82rem;">Verify &amp; issue receipt</button>
                                    <button type="button" onclick="rejectFeeSubmission('<%= record._id %>')" style="background:#f1f5f9;color:#64748b;border:none;padding:0.45rem 1rem;border-radius:6px;font-weight:700;cursor:pointer;font-size:0.82rem;">Reject / clear</button>
                                </div>
                            </div>
                        <% } else { %>
                            <p style="color: #dc2626; font-size: 0.85rem; margin-top: 0.5rem;">Awaiting student payment (Razorpay checkout on student dashboard) ⏳</p>
                        <% } %>
                    </div>

                    <!-- Results Section -->
                    <div>
                        <h4 style="margin-bottom: 0.5rem; color: var(--primary);">Add Result</h4>
                        <div style="display: flex; gap: 0.5rem; margin-bottom: 1rem; flex-wrap: wrap;">
                            <input type="text" id="resSub_<%= record._id %>" placeholder="Subject" style="padding: 0.5rem; border: 1px solid var(--border); border-radius: 4px; flex: 1;">
                            <input type="text" id="resMarks_<%= record._id %>" placeholder="Marks" style="padding: 0.5rem; border: 1px solid var(--border); border-radius: 4px; width: 80px;">
                            <input type="text" id="resGrade_<%= record._id %>" placeholder="Grade" style="padding: 0.5rem; border: 1px solid var(--border); border-radius: 4px; width: 80px;">
                            <button onclick="addResult('<%= record._id %>')" style="background: var(--accent); color: white; border: none; padding: 0.5rem 1rem; border-radius: 4px; cursor: pointer;">Add</button>
                        </div>
                        <% if (record.results && record.results.length > 0) { %>
                            <p style="font-size: 0.85rem; color: var(--text-muted);">Current Results: <%= record.results.length %> entries</p>
                        <% } %>
                    </div>
                </dialog>
            <% }) %>

        <% } %>
    </div>
</div>

<script>
    async function updateFees(id) {
        const feesAmount = document.getElementById(`feeInput_${id}`).value;
        if (!feesAmount) return alert('Please enter a fee amount');

        try {
            const res = await fetch(`/api/admission/fees/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ feesAmount })
            });
            const data = await res.json();
            if (res.ok) {
                alert('Fees updated successfully!');
                window.location.reload();
            } else {
                alert(data.message || 'Failed to update fees');
            }
        } catch (err) {
            alert('Error connecting to server.');
        }
    }

    async function addResult(id) {
        const subject = document.getElementById(`resSub_${id}`).value;
        const marks = document.getElementById(`resMarks_${id}`).value;
        const grade = document.getElementById(`resGrade_${id}`).value;

        if (!subject || !marks || !grade) {
            return alert('Please fill all result fields');
        }

        try {
            const res = await fetch(`/api/admission/results/${id}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ subject, marks, grade })
            });
            const data = await res.json();
            if (res.ok) {
                alert('Result added successfully!');
                window.location.reload();
            } else {
                alert(data.message || 'Failed to add result');
            }
        } catch (err) {
            alert('Error connecting to server.');
        }
    }

    async function verifyFeePayment(id) {
        if (!confirm('Confirm that you received this payment in PhonePe? A receipt will be issued to the student.')) return;
        try {
            const res = await fetch(`/api/admission/verify-fees/${id}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' } });
            const data = await res.json();
            if (res.ok) {
                alert(data.message || 'Verified.');
                window.location.reload();
            } else {
                alert(data.message || 'Failed to verify');
            }
        } catch (e) {
            alert('Error connecting to server.');
        }
    }

    async function rejectFeeSubmission(id) {
        if (!confirm('Clear this submission so the student can enter a different reference?')) return;
        try {
            const res = await fetch(`/api/admission/reject-fee-submission/${id}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' } });
            const data = await res.json();
            if (res.ok) {
                alert(data.message || 'Cleared.');
                window.location.reload();
            } else {
                alert(data.message || 'Failed');
            }
        } catch (e) {
            alert('Error connecting to server.');
        }
    }
</script>

<%- include('partials/footer') %>
