<%- include('partials/header') %>

<div style="min-height: 80vh; display: flex; align-items: center; background: var(--bg-soft); padding: 60px 0;">
    <div class="container">
        <div class="glass-card" style="max-width: 480px; margin: 0 auto; padding: 3.5rem;">
            
            <div id="loginHeader" style="text-align: center; margin-bottom: 2.5rem;">
                <img src="/images/logo.png" alt="Logo" style="height: 60px; margin: 0 auto 1rem;">
                <h2 style="font-size: 2.2rem; color: var(--primary);">Welcome Back</h2>
                <p style="color: var(--text-muted);">Login to access your account</p>
            </div>

            <div id="registerHeader" style="text-align: center; margin-bottom: 2.5rem; display: none;">
                <img src="/images/logo.png" alt="Logo" style="height: 60px; margin: 0 auto 1rem;">
                <h2 style="font-size: 2.2rem; color: var(--primary);">Create Account</h2>
                <p style="color: var(--text-muted);">Register to track your admission</p>
            </div>

            <% if (typeof error !== 'undefined' && error) { %>
                <div style="background: #fee2e2; border: 1px solid #fecaca; color: #991b1b; padding: 1rem 1.2rem; border-radius: 8px; margin-bottom: 2rem; display: flex; align-items: center; gap: 0.8rem; font-weight: 600; font-size: 0.9rem;">
                    <i class="fas fa-exclamation-circle"></i> <%= error %>
                </div>
            <% } %>

            <!-- Login Form -->
            <form id="loginForm" action="/api/auth/login" method="POST">
                <div class="form-group" style="margin-bottom: 1.5rem;">
                    <label>Email Address</label>
                    <input type="email" name="email" placeholder="your@email.com" required autocomplete="email">
                </div>
                <div class="form-group" style="margin-bottom: 2rem;">
                    <label>Password</label>
                    <input type="password" name="password" placeholder="••••••••" required autocomplete="current-password">
                </div>
                <button type="submit" class="btn-yellow" style="width: 100%; text-align: center; font-size: 1rem; padding: 1rem;">
                    <i class="fas fa-sign-in-alt" style="margin-right: 0.5rem;"></i>Login to Account
                </button>
            </form>

            <!-- Register Form (Hidden by default) -->
            <form id="registerForm" action="/api/auth/register" method="POST" style="display: none;">
                <div class="form-group" style="margin-bottom: 1.5rem;">
                    <label>Full Name</label>
                    <input type="text" name="name" placeholder="Enter your full name" required autocomplete="name">
                </div>
                <div class="form-group" style="margin-bottom: 1.5rem;">
                    <label>Email Address</label>
                    <input type="email" name="email" placeholder="your@email.com" required autocomplete="email">
                </div>
                <div class="form-group" style="margin-bottom: 2rem;">
                    <label>Password <span style="color: var(--text-muted); font-weight: 400;">(min. 6 chars)</span></label>
                    <input type="password" name="password" placeholder="Create a password" required minlength="6" autocomplete="new-password">
                </div>
                <button type="submit" class="btn-yellow" style="width: 100%; text-align: center; font-size: 1rem; padding: 1rem;">
                    <i class="fas fa-user-plus" style="margin-right: 0.5rem;"></i>Create Account
                </button>
            </form>

            <div style="text-align: center; margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--border);">
                <p id="toggleToRegister" style="color: var(--text-muted); font-size: 0.92rem;">
                    Don't have an account? 
                    <a href="javascript:void(0)" onclick="toggleAuth('register')" style="color: var(--accent); font-weight: 700;">Register here</a>
                </p>
                <p id="toggleToLogin" style="color: var(--text-muted); font-size: 0.92rem; display: none;">
                    Already have an account? 
                    <a href="javascript:void(0)" onclick="toggleAuth('login')" style="color: var(--accent); font-weight: 700;">Login here</a>
                </p>
                <p style="color: var(--text-muted); font-size: 0.85rem; margin-top: 0.8rem;">
                    <i class="fas fa-shield-alt" style="color: var(--accent); margin-right: 0.3rem;"></i>
                    Admin? Use <strong>admin@rkrschool.com</strong>
                </p>
            </div>
        </div>
    </div>
</div>

<script>
    function toggleAuth(mode) {
        const loginForm = document.getElementById('loginForm');
        const registerForm = document.getElementById('registerForm');
        const loginHeader = document.getElementById('loginHeader');
        const registerHeader = document.getElementById('registerHeader');
        const toggleToRegister = document.getElementById('toggleToRegister');
        const toggleToLogin = document.getElementById('toggleToLogin');

        if (mode === 'register') {
            loginForm.style.display = 'none';
            loginHeader.style.display = 'none';
            toggleToRegister.style.display = 'none';
            
            registerForm.style.display = 'block';
            registerHeader.style.display = 'block';
            toggleToLogin.style.display = 'block';
        } else {
            registerForm.style.display = 'none';
            registerHeader.style.display = 'none';
            toggleToLogin.style.display = 'none';
            
            loginForm.style.display = 'block';
            loginHeader.style.display = 'block';
            toggleToRegister.style.display = 'block';
        }
    }
</script>

<%- include('partials/footer') %>
