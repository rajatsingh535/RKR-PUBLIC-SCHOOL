<%- include('partials/header') %>

<div class="form-wrapper">
    <div class="container">
        <div style="text-align: center; margin-bottom: 4rem;">
            <span class="section-tag" style="color: var(--accent); font-weight: 800; text-transform: uppercase; font-size: 0.9rem; letter-spacing: 2px;">School News</span>
            <h2 style="font-size: 3.5rem; color: var(--primary);">Latest News & Events</h2>
        </div>

        <div class="news-grid">
            <div class="news-card">
                <img src="/images/rkr-kids-craft.jpg" alt="Event" class="news-img">
                <div class="news-body">
                    <div class="news-meta">
                        <span class="news-tag">Event</span>
                        <span class="news-date">12 Sep 2026</span>
                    </div>
                    <h3>Annual Cultural Fest 'Utsav 2026' Concludes with a Grand Show</h3>
                    <p style="color: var(--text-muted); margin-bottom: 1.5rem;">Our annual cultural festival was a resounding success, showcasing the incredible talents of our students in music, dance, and drama.</p>
                    <a href="#" class="read-more">Read More <i class="fas fa-chevron-right"></i></a>
                </div>
            </div>
            <div class="news-card">
                <img src="/images/rkr-science-model.jpg" alt="Achievement" class="news-img">
                <div class="news-body">
                    <div class="news-meta">
                        <span class="news-tag" style="background: #0f172a;">Achievement</span>
                        <span class="news-date">28 Aug 2026</span>
                    </div>
                    <h3>RKRPS Students Win Inter-School Science Quiz Competition</h3>
                    <p style="color: var(--text-muted); margin-bottom: 1.5rem;">Our science team outperformed competitors from 20 other schools to clinch the first prize in the regional science quiz.</p>
                    <a href="#" class="read-more">Read More <i class="fas fa-chevron-right"></i></a>
                </div>
            </div>
            <div class="news-card">
                <img src="/images/hero-3.jpg" alt="Notice" class="news-img">
                <div class="news-body">
                    <div class="news-meta">
                        <span class="news-tag" style="background: #d97706;">Notice</span>
                        <span class="news-date">10 Aug 2026</span>
                    </div>
                    <h3>Independence Day Celebrations — Parents Invited</h3>
                    <p style="color: var(--text-muted); margin-bottom: 1.5rem;">We invite all parents to join us for a flag hoisting ceremony and cultural program on the occasion of Independence Day.</p>
                    <a href="#" class="read-more">Read More <i class="fas fa-chevron-right"></i></a>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
