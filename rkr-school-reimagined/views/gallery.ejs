<%- include('partials/header') %>

<div class="form-wrapper">
    <div class="container">
        <div style="text-align: center; margin-bottom: 4rem;">
            <h2 style="font-size: 3rem;">School Gallery</h2>
            <p style="color: var(--text-muted);">Capturing moments of learning and joy</p>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem;">
            <% const images = ['hero-1.jpg', 'hero-2.jpg', 'hero-3.jpg', 'rkr-diwali.jpg', 'rkr-kids-craft.jpg', 'rkr-science-model.jpg', 'rkr-classroom.jpg', 'rkr-building.jpg']; %>
            <% images.forEach(img => { %>
                <div class="glass-card" style="padding: 0.5rem; overflow: hidden; border-radius: 15px;">
                    <img src="/images/<%= img %>" alt="Gallery Image" style="width: 100%; height: 250px; object-fit: cover; border-radius: 10px; transition: var(--transition); cursor: pointer;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                </div>
            <% }) %>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
