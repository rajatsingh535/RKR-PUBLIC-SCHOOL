<%- include('partials/header') %>

<div class="form-wrapper">
    <div class="container">
        <div style="text-align: center; margin-bottom: 4rem;">
            <h2 style="font-size: 3rem;">Our Story</h2>
            <p style="color: var(--text-muted);">A legacy of excellence in education</p>
        </div>

        <div class="glass-card">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;">
                <div>
                    <h2 style="color: var(--accent); margin-bottom: 1.5rem;">Founded with a Vision</h2>
                    <p style="color: var(--text-muted); margin-bottom: 1rem;">RKR Public School was established in 2000 with a simple yet powerful vision: to provide quality education that is accessible and empowering. Over the last two decades, we have grown from a small institution to one of the most respected schools in the region.</p>
                    <p style="color: var(--text-muted);">We are committed to nurturing the potential of every student, providing them with the tools they need to navigate the complexities of the modern world with confidence and integrity.</p>
                </div>
                <div>
                    <img src="/images/rkr-building.jpg" alt="Building" style="width: 100%; border-radius: 20px; box-shadow: var(--card-shadow);">
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
