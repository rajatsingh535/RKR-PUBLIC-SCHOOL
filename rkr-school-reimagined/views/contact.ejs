<%- include('partials/header') %>

<div class="form-wrapper">
    <div class="container">
        <div style="text-align: center; margin-bottom: 4rem;">
            <h2 style="font-size: 3rem;">Get in Touch</h2>
            <p style="color: var(--text-muted);">We're here to answer any questions you may have.</p>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 4rem;">
            <div class="glass-card" style="padding: 2rem;">
                <h3 style="margin-bottom: 1.5rem; color: var(--accent);">Contact Information</h3>
                <div style="margin-bottom: 1.5rem;">
                    <p style="font-weight: 600; color: white;"><i class="fas fa-map-marker-alt" style="margin-right: 0.5rem; color: var(--accent);"></i> Address</p>
                    <p style="color: var(--text-muted);">Hwy City Vistar Rd, Sajari Gaon, Daheli Sujanpur, Kanpur, UP 208021</p>
                </div>
                <div style="margin-bottom: 1.5rem;">
                    <p style="font-weight: 600; color: white;"><i class="fas fa-phone" style="margin-right: 0.5rem; color: var(--accent);"></i> Phone</p>
                    <p style="color: var(--text-muted);">+91 12345 67890</p>
                </div>
                <div style="margin-bottom: 1.5rem;">
                    <p style="font-weight: 600; color: white;"><i class="fas fa-envelope" style="margin-right: 0.5rem; color: var(--accent);"></i> Email</p>
                    <p style="color: var(--text-muted);">info@rkrpublicschool.com</p>
                </div>
            </div>
            
            <div class="glass-card">
                <form id="contactForm">
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Name</label>
                            <input type="text" required>
                        </div>
                        <div class="form-group">
                            <label>Email</label>
                            <input type="email" required>
                        </div>
                        <div class="form-group full">
                            <label>Message</label>
                            <textarea rows="5" required></textarea>
                        </div>
                    </div>
                    <button type="submit" class="btn-primary">Send Message</button>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
