<%- include('partials/header') %>

<style>
    .dashboard-tabs {
        display: flex; gap: 1rem; margin-top: 2rem; border-bottom: 2px solid var(--border); padding-bottom: 0.5rem; overflow-x: auto;
    }
    .dashboard-tab {
        padding: 0.5rem 1rem; cursor: pointer; font-weight: 500; color: var(--text-muted); border-bottom: 3px solid transparent; transition: all 0.3s;
    }
    .dashboard-tab.active {
        color: var(--primary); border-bottom-color: var(--primary);
    }
    .tab-content {
        display: none; padding-top: 1.5rem;
    }
    .tab-content.active {
        display: block;
    }
    .doc-list {
        list-style: none; padding: 0; margin: 1rem 0;
    }
    .doc-list li {
        display: flex; align-items: center; justify-content: space-between; padding: 1rem; background: var(--bg-soft); border-radius: 8px; margin-bottom: 0.5rem;
    }
    .btn-small {
        padding: 0.5rem 1rem; font-size: 0.85rem; border-radius: 6px; cursor: pointer; border: none; font-weight: 600;
    }
    .btn-small-primary { background: var(--primary); color: white; }
    .btn-small-accent { background: var(--accent); color: white; }
    
    .loader {
        border: 3px solid #f3f3f3; border-top: 3px solid var(--primary); border-radius: 50%; width: 20px; height: 20px; animation: spin 1s linear infinite; display: inline-block; vertical-align: middle; margin-right: 8px;
    }
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

    /* Stripe UI Improvements */
    #payment-element-container {
        margin-top: 1.5rem;
        padding: 1.5rem;
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        text-align: left;
        display: none;
    }
    .payment-header {
        background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
        color: #92400e;
        padding: 2.5rem 2rem;
        border-radius: 16px;
        margin-bottom: 2rem;
        position: relative;
        overflow: hidden;
        border: 1px solid #fde68a;
    }
    .payment-header::after {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 300px;
        height: 300px;
        background: rgba(251, 191, 36, 0.1);
        border-radius: 50%;
    }
    .amount-display {
        font-size: 4rem;
        font-weight: 500;
        color: #b45309;
        margin: 0.5rem 0;
        font-family: 'Outfit', 'Inter', sans-serif;
    }
    .stripe-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(251, 191, 36, 0.2);
        color: #b45309;
        padding: 0.5rem 1.2rem;
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 500;
    }
    .payment-header h4 {
        font-weight: 500;
        letter-spacing: 1px;
        color: #92400e;
    }
</style>

<div style="background: var(--primary); padding: 4rem 0;">
    <div class="container">
        <span class="section-tag" style="color: var(--accent-light);">My Portal</span>
        <h2 style="color: white; font-size: 2.8rem;">Student Dashboard</h2>
        <p style="color: rgba(255,255,255,0.6); margin-top: 0.5rem;">Welcome, <strong style="color: var(--accent-light);"><%= user.name %></strong> — manage your admission below.</p>
    </div>
</div>

<div style="padding: 60px 0; background: var(--bg-soft); min-height: 50vh;">
    <div class="container">
        <% if (!admissions || admissions.length === 0) { %>
            <div class="glass-card" style="text-align: center; padding: 5rem 2rem; max-width: 600px; margin: 0 auto;">
                <i class="fas fa-file-alt" style="font-size: 4rem; color: #cbd5e1; margin-bottom: 1.5rem; display: block;"></i>
                <h3 style="color: var(--primary); font-size: 1.8rem; margin-bottom: 1rem;">No Applications Found</h3>
                <p style="color: var(--text-muted); margin-bottom: 2.5rem;">You have not submitted any admission application yet. Apply now to begin your journey with RKR Public School.</p>
                <a href="/admissions" class="btn-yellow">Apply for Admission</a>
            </div>
        <% } else { %>
            <% admissions.forEach((record, index) => { %>
                <div class="glass-card" style="margin-bottom: 2rem; max-width: 900px; margin-left: auto; margin-right: auto;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1.5rem; margin-bottom: 1rem;">
                        <div>
                            <h3 style="color: var(--primary); font-size: 1.6rem; margin-bottom: 0.3rem;"><%= record.studentName %></h3>
                            <p style="color: var(--text-muted);">Applying for <strong>Class <%= record.classApplying %></strong> · Ref: <%= record._id.toString().substring(18,24).toUpperCase() %></p>
                        </div>
                        <div>
                            <% if (record.status === 'Approved') { %>
                                <span style="display:inline-flex;align-items:center;gap:0.6rem;background:#d1fae5;color:#065f46;padding:0.6rem 1.5rem;border-radius:8px;font-weight:700;font-size:0.9rem;"><i class="fas fa-check-circle"></i> Approved</span>
                            <% } else if (record.status === 'Rejected') { %>
                                <span style="display:inline-flex;align-items:center;gap:0.6rem;background:#fee2e2;color:#991b1b;padding:0.6rem 1.5rem;border-radius:8px;font-weight:700;font-size:0.9rem;"><i class="fas fa-times-circle"></i> Rejected</span>
                            <% } else { %>
                                <span style="display:inline-flex;align-items:center;gap:0.6rem;background:#fef3c7;color:#92400e;padding:0.6rem 1.5rem;border-radius:8px;font-weight:700;font-size:0.9rem;"><i class="fas fa-clock"></i> Pending Review</span>
                            <% } %>
                        </div>
                    </div>

                    <!-- Dashboard Tabs -->
                    <div class="dashboard-tabs">
                        <div class="dashboard-tab active" onclick="switchTab(this, 'tab-status-<%= index %>')">Status</div>
                        <div class="dashboard-tab" onclick="switchTab(this, 'tab-docs-<%= index %>')">Documents</div>
                        <div class="dashboard-tab" onclick="switchTab(this, 'tab-fees-<%= index %>')">Fees Payment</div>
                        <div class="dashboard-tab" onclick="switchTab(this, 'tab-results-<%= index %>')">Results</div>
                    </div>

                    <!-- TAB: Status -->
                    <div id="tab-status-<%= index %>" class="tab-content active">
                        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem;">
                            <div><p style="font-size:0.78rem;text-transform:uppercase;color:var(--text-muted);margin-bottom:0.3rem;">Parent Name</p><p style="font-weight:700;color:var(--primary);"><%= record.parentName %></p></div>
                            <div><p style="font-size:0.78rem;text-transform:uppercase;color:var(--text-muted);margin-bottom:0.3rem;">Phone</p><p style="font-weight:700;color:var(--primary);"><%= record.phone %></p></div>
                            <div><p style="font-size:0.78rem;text-transform:uppercase;color:var(--text-muted);margin-bottom:0.3rem;">Email</p><p style="font-weight:700;color:var(--primary);"><%= record.email %></p></div>
                            <div><p style="font-size:0.78rem;text-transform:uppercase;color:var(--text-muted);margin-bottom:0.3rem;">Date of Birth</p><p style="font-weight:700;color:var(--primary);"><%= record.dob %></p></div>
                            <div><p style="font-size:0.78rem;text-transform:uppercase;color:var(--text-muted);margin-bottom:0.3rem;">Gender</p><p style="font-weight:700;color:var(--primary);"><%= record.gender %></p></div>
                            <div><p style="font-size:0.78rem;text-transform:uppercase;color:var(--text-muted);margin-bottom:0.3rem;">Occupation</p><p style="font-weight:700;color:var(--primary);"><%= record.occupation || 'N/A' %></p></div>
                            <div style="grid-column: 1 / -1;"><p style="font-size:0.78rem;text-transform:uppercase;color:var(--text-muted);margin-bottom:0.3rem;">Residential Address</p><p style="font-weight:700;color:var(--primary);"><%= record.address %></p></div>
                        </div>
                        <% if (record.status === 'Pending') { %>
                            <div style="padding: 1.2rem 1.5rem; background: #fffbf2; border: 1px solid #e9d8a6; border-radius: 8px; display: flex; align-items: center; gap: 1rem;">
                                <i class="fas fa-info-circle" style="color: var(--accent);"></i>
                                <p style="color: var(--text-muted); font-size: 0.92rem; margin: 0;">Your application is under review. Please upload required documents in the Documents tab.</p>
                            </div>
                        <% } %>
                    </div>

                    <!-- TAB: Documents -->
                    <div id="tab-docs-<%= index %>" class="tab-content">
                        <h4>Uploaded Documents</h4>
                        <% if (!record.documents || record.documents.length === 0) { %>
                            <p style="color: var(--text-muted); font-size: 0.9rem;">No documents uploaded yet.</p>
                        <% } else { %>
                            <ul class="doc-list">
                                <% (record.documents || []).forEach(doc => { %>
                                    <li>
                                        <div>
                                            <i class="fas fa-file-image" style="color: var(--primary); margin-right: 8px;"></i>
                                            <strong><%= doc.name %></strong>
                                        </div>
                                        <a href="<%= doc.data %>" download="<%= doc.name %>" class="btn-small btn-small-accent">View/Download</a>
                                    </li>
                                <% }) %>
                            </ul>
                        <% } %>
                        
                        <div style="margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px dashed var(--border);">
                            <h4 style="margin-bottom: 1rem;">Upload New Document</h4>
                            <form onsubmit="handleUpload(event, '<%= record._id %>')" style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
                                <input type="text" id="docName_<%= record._id %>" placeholder="Document Name (e.g. Aadhar)" required style="padding: 0.5rem; border-radius: 6px; border: 1px solid var(--border);">
                                <input type="file" id="docFile_<%= record._id %>" accept="image/*,.pdf" required style="font-size: 0.9rem;">
                                <button type="submit" class="btn-small btn-small-primary" id="btnUpload_<%= record._id %>">Upload</button>
                            </form>
                            <p style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.5rem;">Note: Max file size 2MB. Image or PDF preferred.</p>
                        </div>
                    </div>

                    <!-- TAB: Fees -->
                    <div id="tab-fees-<%= index %>" class="tab-content">
                        <% if (record.status !== 'Approved') { %>
                            <div style="text-align: center; padding: 4rem 2rem;">
                                <div style="width: 80px; height: 80px; background: #f1f5f9; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
                                    <i class="fas fa-lock" style="font-size: 2rem; color: #94a3b8;"></i>
                                </div>
                                <h4 style="color: var(--primary); margin-bottom: 0.5rem;">Payment Locked</h4>
                                <p style="color: var(--text-muted); max-width: 300px; margin: 0 auto;">Fee payment will be unlocked once your application is officially Approved by the school.</p>
                            </div>
                        <% } else { %>
                            <div class="payment-card">
                                <div class="payment-header">
                                    <div style="display: flex; justify-content: space-between; align-items: center;">
                                        <h4 style="margin: 0; font-weight: 600; opacity: 0.9;">ADMISSION FEES</h4>
                                        <div class="stripe-badge">
                                            <i class="fab fa-stripe" style="font-size: 1.5rem;"></i>
                                            <span>Secure Payment</span>
                                        </div>
                                    </div>
                                    <h2 class="amount-display">₹<%= record.feesAmount || 0 %></h2>
                                    <p style="opacity: 0.8; font-size: 0.95rem; margin-top: 0.5rem;">
                                        <%= record.feesPaid ? 'Payment successfully completed' : 'Complete your admission process by paying the fees securely via Stripe.' %>
                                    </p>
                                </div>

                                <% if (record.feesPaid) { %>
                                    <div style="background: white; border-radius: 12px; padding: 2.5rem; text-align: center; border: 1px solid #e2e8f0;">
                                        <div style="width: 60px; height: 60px; background: #d1fae5; color: #059669; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
                                            <i class="fas fa-check" style="font-size: 1.5rem;"></i>
                                        </div>
                                        <h3 style="color: #065f46; margin-bottom: 0.5rem;">Payment Verified</h3>
                                        <% if (record.receiptNumber) { %>
                                            <p style="color: var(--text-muted); margin-bottom: 2rem;">Receipt No: <strong style="color: var(--primary);"><%= record.receiptNumber %></strong></p>
                                        <% } %>
                                        <div style="display: flex; gap: 1rem; justify-content: center;">
                                            <a href="/receipt/<%= record._id %>" target="_blank" class="btn-yellow" style="padding: 0.8rem 2rem;">
                                                <i class="fas fa-print" style="margin-right: 8px;"></i> View Receipt
                                            </a>
                                        </div>
                                    </div>
                                <% } else if (record.feesAmount > 0) { %>
                                    <div id="payment-trigger-container-<%= record._id %>" style="text-align: center;">
                                        <button type="button" onclick="initiateStripePayment('<%= record._id %>')" id="btnPay_<%= record._id %>" class="btn-yellow" style="width: 100%; max-width: 400px; padding: 1.2rem; font-size: 1.1rem; border-radius: 12px; font-weight: 500; box-shadow: 0 10px 15px -3px rgba(251, 191, 36, 0.2); background: #d97706; color: white;">
                                            Proceed to Payment
                                        </button>
                                        <div style="display: flex; justify-content: center; gap: 1.5rem; margin-top: 1.5rem; opacity: 0.4;">
                                            <i class="fab fa-cc-visa fa-2x"></i>
                                            <i class="fab fa-cc-mastercard fa-2x"></i>
                                            <i class="fab fa-google-pay fa-2x"></i>
                                            <i class="fab fa-apple-pay fa-2x"></i>
                                        </div>
                                    </div>

                                    <div id="payment-element-container-<%= record._id %>" style="display: none; max-width: 500px; margin: 0 auto;">
                                        <div style="margin-bottom: 1.5rem; display: flex; align-items: center; justify-content: space-between;">
                                            <h5 style="margin: 0;">Payment Details</h5>
                                            <button onclick="cancelPayment('<%= record._id %>')" style="background: none; border: none; color: var(--text-muted); cursor: pointer; font-size: 0.85rem;">Cancel</button>
                                        </div>
                                        <form id="payment-form-<%= record._id %>">
                                            <div id="link-authentication-element-<%= record._id %>"></div>
                                            <div id="payment-element-<%= record._id %>"></div>
                                            <button id="submit-payment-<%= record._id %>" class="btn-yellow" style="width: 100%; margin-top: 1.5rem; padding: 1rem;">
                                                <span id="button-text-<%= record._id %>">Pay Now</span>
                                                <span id="payment-loader-<%= record._id %>" class="loader" style="display: none;"></span>
                                            </button>
                                            <div id="payment-message-<%= record._id %>" style="margin-top: 1rem; color: #dc2626; font-size: 0.9rem; display: none; text-align: center;"></div>
                                        </form>
                                    </div>
                                <% } else { %>
                                    <div style="background: white; border-radius: 12px; padding: 3rem 2rem; text-align: center; border: 1px dashed #cbd5e1;">
                                        <i class="fas fa-hourglass-half" style="font-size: 2.5rem; color: #cbd5e1; margin-bottom: 1.5rem;"></i>
                                        <p style="color: var(--text-muted); margin: 0;">Fee amount has not been assigned yet. Please check back later or contact the school office.</p>
                                    </div>
                                <% } %>
                            </div>
                        <% } %>
                    </div>

                    <!-- TAB: Results -->
                    <div id="tab-results-<%= index %>" class="tab-content">
                        <% if (!record.results || record.results.length === 0) { %>
                            <div style="text-align: center; padding: 2rem;">
                                <i class="fas fa-chart-line" style="font-size: 2rem; color: #cbd5e1; margin-bottom: 1rem;"></i>
                                <p style="color: var(--text-muted);">No academic results published yet.</p>
                            </div>
                        <% } else { %>
                            <table style="width: 100%; border-collapse: collapse; margin-top: 1rem;">
                                <thead>
                                    <tr style="background: var(--primary); color: white; text-align: left;">
                                        <th style="padding: 1rem; border-radius: 8px 0 0 0;">Subject/Term</th>
                                        <th style="padding: 1rem;">Marks</th>
                                        <th style="padding: 1rem; border-radius: 0 8px 0 0;">Grade</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% (record.results || []).forEach(result => { %>
                                        <tr style="border-bottom: 1px solid var(--border);">
                                            <td style="padding: 1rem; font-weight: 600;"><%= result.subject %></td>
                                            <td style="padding: 1rem;"><%= result.marks %></td>
                                            <td style="padding: 1rem; color: var(--accent); font-weight: bold;"><%= result.grade %></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        <% } %>
    </div>
</div>

<script src="https://js.stripe.com/v3/"></script>
<script>
    let stripe;
    let elements;
    let currentRecordId;

    function switchTab(element, tabId) {
        const tabsContainer = element.parentElement;
        const cardContainer = tabsContainer.parentElement;
        tabsContainer.querySelectorAll('.dashboard-tab').forEach(t => t.classList.remove('active'));
        element.classList.add('active');
        cardContainer.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
        document.getElementById(tabId).classList.add('active');
    }

    async function handleUpload(e, id) {
        e.preventDefault();
        const btn = document.getElementById(`btnUpload_${id}`);
        const nameInput = document.getElementById(`docName_${id}`);
        const fileInput = document.getElementById(`docFile_${id}`);
        if (!fileInput.files || fileInput.files.length === 0) return alert('Please select a file');
        const file = fileInput.files[0];
        if (file.size > 2 * 1024 * 1024) return alert('File size must be under 2MB.');
        btn.innerHTML = '<span class="loader"></span> Uploading...';
        btn.disabled = true;
        const reader = new FileReader();
        reader.onloadend = async function() {
            const base64data = reader.result;
            try {
                const res = await fetch(`/api/admission/upload/${id}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name: nameInput.value, fileType: file.type, data: base64data })
                });
                const result = await res.json();
                if (res.ok) { alert('Document uploaded successfully!'); window.location.reload(); }
                else { alert(result.message || 'Upload failed'); btn.innerHTML = 'Upload'; btn.disabled = false; }
            } catch (err) { alert('Error connecting to server.'); btn.innerHTML = 'Upload'; btn.disabled = false; }
        };
        reader.readAsDataURL(file);
    }

    // --- STRIPE INTEGRATION ---

    function cancelPayment(id) {
        document.getElementById(`payment-trigger-container-${id}`).style.display = 'block';
        document.getElementById(`payment-element-container-${id}`).style.display = 'none';
    }

    async function initiateStripePayment(id) {
        currentRecordId = id;
        const btn = document.getElementById(`btnPay_${id}`);
        const triggerContainer = document.getElementById(`payment-trigger-container-${id}`);
        const elementContainer = document.getElementById(`payment-element-container-${id}`);
        
        btn.innerHTML = '<span class="loader"></span> Loading Stripe...';
        btn.disabled = true;

        try {
            const res = await fetch(`/api/admission/pay-fees/${id}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            const data = await res.json();

            if (!res.ok) {
                alert(data.message || 'Error creating payment intent');
                btn.innerHTML = 'Proceed to Payment';
                btn.disabled = false;
                return;
            }

            stripe = Stripe(data.publishableKey);
            
            const appearance = {
                theme: 'stripe',
                variables: {
                    colorPrimary: '#1e293b',
                    colorBackground: '#ffffff',
                    colorText: '#1e293b',
                    colorDanger: '#df1b41',
                    fontFamily: 'Inter, system-ui, sans-serif',
                    spacingUnit: '4px',
                    borderRadius: '8px',
                },
            };

            elements = stripe.elements({ appearance, clientSecret: data.clientSecret });

            const paymentElementOptions = { layout: "tabs" };
            const paymentElement = elements.create("payment", paymentElementOptions);
            paymentElement.mount(`#payment-element-${id}`);

            triggerContainer.style.display = 'none';
            elementContainer.style.display = 'block';

            const form = document.getElementById(`payment-form-${id}`);
            form.addEventListener('submit', (e) => handleSubmit(e, id));

            btn.innerHTML = 'Proceed to Payment';
            btn.disabled = false;

        } catch (err) {
            console.error(err);
            alert('Could not connect to payment gateway.');
            btn.innerHTML = 'Proceed to Payment';
            btn.disabled = false;
        }
    }

    async function handleSubmit(e, id) {
        e.preventDefault();
        const submitBtn = document.getElementById(`submit-payment-${id}`);
        const btnText = document.getElementById(`button-text-${id}`);
        const loader = document.getElementById(`payment-loader-${id}`);
        const messageDiv = document.getElementById(`payment-message-${id}`);

        submitBtn.disabled = true;
        btnText.style.display = 'none';
        loader.style.display = 'inline-block';
        messageDiv.style.display = 'none';

        const { error, paymentIntent } = await stripe.confirmPayment({
            elements,
            redirect: 'if_required',
            confirmParams: {
                // Return URL for fallback if redirect happens
                return_url: window.location.origin + "/status",
            },
        });

        if (error) {
            if (error.type === "card_error" || error.type === "validation_error") {
                messageDiv.textContent = error.message;
            } else {
                messageDiv.textContent = "An unexpected error occurred.";
            }
            messageDiv.style.display = 'block';
            submitBtn.disabled = false;
            btnText.style.display = 'inline-block';
            loader.style.display = 'none';
        } else if (paymentIntent && paymentIntent.status === "succeeded") {
            // Payment successful, verify on server
            verifyOnServer(id, paymentIntent.id);
        }
    }

    async function verifyOnServer(id, paymentIntentId) {
        try {
            const res = await fetch(`/api/admission/verify-payment/${id}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ paymentIntentId })
            });
            const data = await res.json();
            if (res.ok) {
                alert('Payment successful! Your receipt has been generated.');
                window.location.reload();
            } else {
                alert(data.message || 'Verification failed. Please contact support.');
                window.location.reload();
            }
        } catch (err) {
            alert('Payment confirmed but verification failed. Please refresh or contact support.');
            window.location.reload();
        }
    }
</script>

<%- include('partials/footer') %>
