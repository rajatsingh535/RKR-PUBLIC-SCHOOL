<%- include('partials/header') %>

<div class="form-wrapper">
    <div class="container">
        <div style="text-align: center; margin-bottom: 4rem;">
            <span class="section-tag" style="color: var(--accent); font-weight: 800; text-transform: uppercase; font-size: 0.9rem; letter-spacing: 2px;">Academic Excellence</span>
            <h2 style="font-size: 3.5rem; color: var(--primary);">Our Pride & Achievements</h2>
            <p style="color: var(--text-muted); margin-top: 1rem;">Celebrating the success of our bright students who excel in every field.</p>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 3rem;">
            <div class="glass-card" style="text-align: center; padding: 3rem;">
                <div style="position: relative; width: 200px; height: 200px; margin: 0 auto 2rem;">
                    <img src="/images/rkr-toppers-1.jpg" alt="Board Topper" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover; border: 8px solid var(--accent-light); box-shadow: 0 10px 30px rgba(217, 119, 6, 0.3);">
                    <div style="position: absolute; bottom: 0; right: 10px; background: var(--primary); color: white; width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; border: 3px solid var(--white);">
                        <i class="fas fa-medal"></i>
                    </div>
                </div>
                <h3 style="color: var(--primary); font-size: 1.8rem;">Class X District Topper</h3>
                <p style="color: var(--text-muted); margin-top: 1rem; font-size: 1.1rem;">Consistent performance in CBSE Board Exams with 98.4% aggregate.</p>
            </div>

            <div class="glass-card" style="text-align: center; padding: 3rem;">
                <div style="position: relative; width: 200px; height: 200px; margin: 0 auto 2rem;">
                    <img src="/images/rkr-toppers-2.jpg" alt="Science Winner" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover; border: 8px solid var(--accent-light); box-shadow: 0 10px 30px rgba(217, 119, 6, 0.3);">
                    <div style="position: absolute; bottom: 0; right: 10px; background: var(--primary); color: white; width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; border: 3px solid var(--white);">
                        <i class="fas fa-trophy"></i>
                    </div>
                </div>
                <h3 style="color: var(--primary); font-size: 1.8rem;">Science Olympiad Winner</h3>
                <p style="color: var(--text-muted); margin-top: 1rem; font-size: 1.1rem;">Secured International Rank 5 in the Unified Science Olympiad 2025.</p>
            </div>

            <div class="glass-card" style="text-align: center; padding: 3rem;">
                <div style="position: relative; width: 200px; height: 200px; margin: 0 auto 2rem;">
                    <img src="/images/rkr-science-model.jpg" alt="Innovation" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover; border: 8px solid var(--accent-light); box-shadow: 0 10px 30px rgba(217, 119, 6, 0.3);">
                    <div style="position: absolute; bottom: 0; right: 10px; background: var(--primary); color: white; width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; border: 3px solid var(--white);">
                        <i class="fas fa-lightbulb"></i>
                    </div>
                </div>
                <h3 style="color: var(--primary); font-size: 1.8rem;">Innovation Award</h3>
                <p style="color: var(--text-muted); margin-top: 1rem; font-size: 1.1rem;">First prize in Regional Science Exhibition for 'Eco-Friendly Energy' model.</p>
            </div>
        </div>
        
        <div style="margin-top: 5rem; text-align: center;">
            <h3 style="font-size: 2.5rem; color: var(--primary); margin-bottom: 3rem;">Sports & Co-curricular</h3>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
                <img src="/images/facility-sports.jpg" alt="Sports" style="width: 100%; border-radius: 15px; box-shadow: var(--card-shadow);">
                <img src="/images/rkr-kids-craft.jpg" alt="Arts" style="width: 100%; border-radius: 15px; box-shadow: var(--card-shadow);">
                <img src="/images/rkr-diwali.jpg" alt="Cultural" style="width: 100%; border-radius: 15px; box-shadow: var(--card-shadow);">
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
