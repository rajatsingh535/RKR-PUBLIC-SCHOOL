<%- include('partials/header') %>

<div class="form-wrapper">
    <div class="container">
        <div style="text-align: center; margin-bottom: 4rem;">
            <h2 style="font-size: 3rem;">Academics</h2>
            <p style="color: var(--text-muted);">A curriculum designed for the 21st century</p>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 2.5rem;">
            <div class="glass-card" style="padding: 2.5rem;">
                <h3 style="color: var(--accent); margin-bottom: 1rem;">Primary School</h3>
                <p style="color: var(--text-muted); margin-bottom: 1.5rem;">Focusing on foundational literacy and numeracy through activity-based learning.</p>
                <ul style="list-style: none; color: var(--text-muted);">
                    <li><i class="fas fa-check" style="color: var(--accent); margin-right: 0.5rem;"></i> Playway Method</li>
                    <li><i class="fas fa-check" style="color: var(--accent); margin-right: 0.5rem;"></i> Language Arts</li>
                    <li><i class="fas fa-check" style="color: var(--accent); margin-right: 0.5rem;"></i> Basic Mathematics</li>
                </ul>
            </div>
            <div class="glass-card" style="padding: 2.5rem;">
                <h3 style="color: var(--accent); margin-bottom: 1rem;">Middle School</h3>
                <p style="color: var(--text-muted); margin-bottom: 1.5rem;">Broadening horizons with a focus on science, social studies, and languages.</p>
                <ul style="list-style: none; color: var(--text-muted);">
                    <li><i class="fas fa-check" style="color: var(--accent); margin-right: 0.5rem;"></i> Integrated Science</li>
                    <li><i class="fas fa-check" style="color: var(--accent); margin-right: 0.5rem;"></i> Social Sciences</li>
                    <li><i class="fas fa-check" style="color: var(--accent); margin-right: 0.5rem;"></i> Second Languages</li>
                </ul>
            </div>
            <div class="glass-card" style="padding: 2.5rem;">
                <h3 style="color: var(--accent); margin-bottom: 1rem;">Senior Secondary</h3>
                <p style="color: var(--text-muted); margin-bottom: 1.5rem;">Specialized streams in Science, Commerce, and Humanities.</p>
                <ul style="list-style: none; color: var(--text-muted);">
                    <li><i class="fas fa-check" style="color: var(--accent); margin-right: 0.5rem;"></i> Career Counseling</li>
                    <li><i class="fas fa-check" style="color: var(--accent); margin-right: 0.5rem;"></i> Competitive Exam Prep</li>
                    <li><i class="fas fa-check" style="color: var(--accent); margin-right: 0.5rem;"></i> Project-based Learning</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
