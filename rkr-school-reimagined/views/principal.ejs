<%- include('partials/header') %>

<div class="form-wrapper">
    <div class="container">
        <div style="text-align: center; margin-bottom: 4rem;">
            <span class="section-tag" style="color: var(--accent); font-weight: 800; text-transform: uppercase; font-size: 0.9rem; letter-spacing: 2px;">Leadership</span>
            <h2 style="font-size: 3.5rem; color: var(--primary);">Principal's Message</h2>
        </div>

        <div class="glass-card">
            <div style="display: grid; grid-template-columns: 1fr 1.5fr; gap: 5rem; align-items: start;">
                <div class="principal-img-container">
                    <img src="/images/rkr-principal.jpg" alt="Principal" class="principal-img" style="box-shadow: 20px 20px 0px var(--accent-light);">
                </div>
                <div class="principal-content">
                    <h3 style="font-size: 2.2rem; color: var(--primary); margin-bottom: 1.5rem;">A Message from Mr. Harish Singh Padihar</h3>
                    <div style="color: var(--text-muted); font-size: 1.1rem; line-height: 1.8;">
                        <p style="margin-bottom: 1.5rem;">"It is with great pleasure that I welcome you to R.K.R. Public School. Our mission is to provide an education that not only challenges the mind but also inspires the heart. We believe that every student has the potential to achieve greatness, and it is our job to provide the environment and support they need to reach their goals."</p>
                        <p style="margin-bottom: 1.5rem;">"In today's rapidly changing world, education must go beyond textbooks. We focus on developing critical thinking, creativity, and emotional intelligence. Our dedicated faculty works tirelessly to ensure that our students are not only academically proficient but also ethically grounded."</p>
                        <p style="margin-bottom: 1.5rem;">"We take pride in our diverse community and our commitment to inclusivity. Whether it's through our advanced science labs, our vibrant arts programs, or our competitive sports teams, we offer every child a platform to excel."</p>
                        <p>"I invite you to explore our campus and discover what makes RKRPS a truly special place for learning and growth."</p>
                    </div>
                    <div class="principal-info" style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--glass-border);">
                        <h4>Mr. Harish Singh Padihar</h4>
                        <p style="color: var(--accent); font-weight: 700;">Principal, RKR Public School</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
